# Server Configuration
PORT=5000

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/mental_health_analytics

# JWT Secret (change this in production!)
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d

# Comma-separated browser origins allowed to call this API (required for Vercel + credentials)
# Example: https://your-app.vercel.app,https://your-app-git-main-team.vercel.app
ALLOWED_ORIGINS=
